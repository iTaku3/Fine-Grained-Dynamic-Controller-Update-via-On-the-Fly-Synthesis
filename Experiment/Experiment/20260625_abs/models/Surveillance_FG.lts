// —————————–COMMENTS—————————––

// - To execute the solution for update controllers select in the dropdown menu
// the “UPDATE_CONTROLLER” label, and then press the compose button (||).
// - In the section of UPDATING CONTROLLER SPEC, in this file, you can spec
// different transition requeriments presented in the paper.
// - You can animate the controller obtained pressing the blue A in the top bar
// - After composing, you can validate that the controller obtained satisfy
// each updating controller goal formula by modelchecking.

// —————————ENVIRONMENTS—————————–

const LOWBAT = 1
const MAXBAT = 10
const MAXWEATHER = 2

set ControllableActions = {return2base, move, low, mid, high, scan, picture, takeoff}
set NewControllableActions = {ControllableActions, follow, weather}
//set NewControllableActions = {ControllableActions, follow}
set AlphabetOld = {return2base, move, low, mid, high, scan, picture, takeoff,
scan.val[0..1], pictureOk[0..1], lowBattery}
set AlphabetNew = {return2base, move, low, mid, high, scan, picture, follow, takeoff,
scan.val[0..1], pictureOk[0..1], lowBattery}
set EnergyConsumingActionsOld = {move, high, mid, low, scan, picture}
set EnergyConsumingActionsNew = {move, high, mid, low, scan, picture, follow}
set AnyActionSet = {return2base, move, low, mid, high, scan, picture, follow, lowBattery, pictureOk[0..1], scan.val[0..1]}

//oldEnvironment
MISSION			= (takeoff -> HEIGHT),
HEIGHT			= ({low,mid,high} -> UAV),
UAV				= ({move,low,mid,high} -> UAV
| return2base -> MISSION
| picture -> TAKING_PICTURE
| scan -> SCANING),
TAKING_PICTURE	= (pictureOk[0..1] -> UAV),
SCANING		= (scan.val[0..1] -> UAV).
BATTERY_COUNTER(N=MAXBAT)	= BAT[N],
BAT[i:0..N]					= (when (i==LOWBAT) lowBattery -> BAT[i-1]
|  when (i>LOWBAT) {move,high,mid,low, scan, picture} -> BAT[i-1]
|  when (i == 0) {move,high,mid,low, scan, picture} -> BAT[0]
|  return2base -> BAT[N]).

//newEnvironment
NEW_MISSION     = (takeoff -> HEIGHT),
HEIGHT			= ({high,mid,low} -> UAV),
UAV             = ({follow,move,high,mid,low} -> UAV
| return2base -> NEW_MISSION
| picture -> TAKING_PICTURE
| scan -> SCANING),
TAKING_PICTURE	= (pictureOk[0..1] -> UAV),
SCANING		= (scan.val[0..1] -> UAV).
NEW_BATTERY_COUNTER(N=MAXBAT)	= BAT[N],
BAT[i:0..N]						= (when (i==LOWBAT) lowBattery -> BAT[i-1]
|  when (i>LOWBAT) {move,high,mid,low, scan, picture, follow} -> BAT[i-1]
|  when (i == 0) {move,high,mid,low, scan, picture, follow} -> BAT[0]
|  return2base -> BAT[N]).

//relation
relation R_MISSION = {MISSION@MISSION		 = reconfigure -> NEW_MISSION@NEW_MISSION,
HEIGHT@MISSION		 = reconfigure -> HEIGHT@NEW_MISSION,
UAV@MISSION			 = reconfigure -> UAV@NEW_MISSION,
TAKING_PICTURE@MISSION = reconfigure -> TAKING_PICTURE@NEW_MISSION,
SCANING@MISSION		 = reconfigure -> SCANING@NEW_MISSION}
relation R_MISSION_FG = {MISSION@MISSION	    = reconfigure_MISSION -> NEW_MISSION@NEW_MISSION,
HEIGHT@MISSION		    = reconfigure_MISSION -> HEIGHT@NEW_MISSION,
UAV@MISSION			= reconfigure_MISSION -> UAV@NEW_MISSION,
TAKING_PICTURE@MISSION = reconfigure_MISSION -> TAKING_PICTURE@NEW_MISSION,
SCANING@MISSION		= reconfigure_MISSION -> SCANING@NEW_MISSION}

relation R_BATTERY_COUNTER = {forall [i:0..MAXBAT] BAT[i]@BATTERY_COUNTER= reconfigure -> BAT[i]@NEW_BATTERY_COUNTER}

relation R_BATTERY_COUNTER_FG = {forall [i:0..MAXBAT] BAT[i]@BATTERY_COUNTER= reconfigure_BATTERY_COUNTER -> BAT[i]@NEW_BATTERY_COUNTER}

map MAP_MISSION = {MISSION, NEW_MISSION, R_MISSION}.

map MAP_BATTERY_COUNTER = {BATTERY_COUNTER, NEW_BATTERY_COUNTER, R_BATTERY_COUNTER}.

||OldEnvironment = (MISSION || BATTERY_COUNTER).
||NewEnvironment = (NEW_MISSION || NEW_BATTERY_COUNTER).
||MapEnvironment = (MAP_MISSION || MAP_BATTERY_COUNTER).

// —————————OLD CONTROLLER SPEC—————————–

//Fluents declaration
fluent FlyingHigh = <high,{mid,low,return2base}>
fluent FlyingMid = <mid,{high,low,return2base}>
fluent FlyingLow = <low,{mid,high,return2base}>
fluent ScanPending	  = <scan,scan.val[0..1]>
fluent ZoneScaned = <{scan.val[0], scan.val[1]},{move,return2base}>
fluent SuspiciousActivityDetected = <scan.val[1],{move,return2base}>
fluent NewSuspiciousActivityDetected = <scan.val[1],{return2base}>
fluent ScanProcessing	= <scan,{scan.val[0],pictureOk[1],return2base}>
fluent PictureSent		= <pictureOk[1],{move,return2base}>
fluent NoBattery        = <lowBattery,takeoff>
fluent Following = <follow,return2base>
fluent HeightSet = <{high,mid,low},return2base>
fluent MissionStarted = <takeoff,return2base>
fluent ScanFailed	  = <scan.val[0],{move,return2base}>
fluent PicturePending   = <picture,pictureOk[0..1]>

fluent BatteryIsEmpty = <lowBattery, return2base>
fluent JustDidEnergyActionOld = <EnergyConsumingActionsOld, {AlphabetOld}\{EnergyConsumingActionsOld}>
fluent JustDidEnergyActionNew = <EnergyConsumingActionsNew, {AlphabetNew}\{EnergyConsumingActionsNew}>

assert DONT_SCAN_TWICE			= (scan ->!ZoneScaned)
assert ALWAYS_FLY_HIGH 			= (MissionStarted -> (!FlyingLow && !FlyingMid))
assert HOW_TO_MOVE				= ((move-> !ScanProcessing))
assert DONT_PICTURE_TWICE		= (picture -> !PictureSent)
assert DETECTED_ACTIONS  		= ((picture-> SuspiciousActivityDetected) && (scan -> !SuspiciousActivityDetected))
assert HIGH_PRIORITY_TO_MISSION = (return2base-> NoBattery)

assert NoActionWhenEmptyOld = !(BatteryIsEmpty && JustDidEnergyActionOld)
ltl_property P_BATTERY_SAFETY_OLD = []NoActionWhenEmptyOld

ltl_property P_DONT_SCAN_TWICE = []DONT_SCAN_TWICE
ltl_property P_ALWAYS_FLY_HIGH = []ALWAYS_FLY_HIGH
ltl_property P_HOW_TO_MOVE = []HOW_TO_MOVE
ltl_property P_DONT_PICTURE_TWICE = []DONT_PICTURE_TWICE
ltl_property P_DETECTED_ACTIONS = []DETECTED_ACTIONS
ltl_property P_HIGH_PRIORITY_TO_MISSION = []HIGH_PRIORITY_TO_MISSION

controllerSpec OldSpec = {
safety = {P_ALWAYS_FLY_HIGH, P_DETECTED_ACTIONS, P_HIGH_PRIORITY_TO_MISSION, P_HOW_TO_MOVE, P_DONT_PICTURE_TWICE, P_DONT_SCAN_TWICE, P_BATTERY_SAFETY_OLD}
controllable = {ControllableActions}
}

controller ||OldController = OldEnvironment~{OldSpec}.
||OldC = OldController.
||EnvironmentAndController = (OldController || OldEnvironment).

// —————————NEW CONTROLLER SPEC—————————–

assert ALWAYS_FLY_LOW = (MissionStarted -> (!FlyingHigh && !FlyingMid))
assert NEW_HOW_TO_MOVE = ((move -> !Following) && (move-> !NewSuspiciousActivityDetected))
assert FOLLOWING_ACTIONS = ((picture -> Following) && (scan -> !Following) &&
(scan-> !SuspiciousActivityDetected) && (PictureSent -> !follow))
assert NO_FOLLOW_BEFORE_SCAN = (follow -> SuspiciousActivityDetected)

assert NoActionWhenEmptyNew = !(BatteryIsEmpty && JustDidEnergyActionNew)
ltl_property P_BATTERY_SAFETY_NEW = []NoActionWhenEmptyNew

ltl_property P_ALWAYS_FLY_LOW = []ALWAYS_FLY_LOW
ltl_property P_NEW_HOW_TO_MOVE = []NEW_HOW_TO_MOVE
ltl_property P_FOLLOWING_ACTIONS = []FOLLOWING_ACTIONS
ltl_property P_NO_FOLLOW_BEFORE_SCAN = []NO_FOLLOW_BEFORE_SCAN

controllerSpec NewSpec = {
safety = {P_ALWAYS_FLY_LOW, P_FOLLOWING_ACTIONS, P_NO_FOLLOW_BEFORE_SCAN, P_HIGH_PRIORITY_TO_MISSION,
P_NEW_HOW_TO_MOVE, P_DONT_SCAN_TWICE, P_BATTERY_SAFETY_NEW}
controllable = {NewControllableActions}
}

controller ||NewController = NewEnvironment~{NewSpec}.
||NewControllerAndNewEnvironment = (NewController || NewEnvironment).

// —————————UPDATING CONTROLLER SPEC—————————–

set StopOldSpecActions = {stopOldSpec_P_ALWAYS_FLY_HIGH, stopOldSpec_P_DETECTED_ACTIONS, stopOldSpec_P_HIGH_PRIORITY_TO_MISSION, stopOldSpec_P_HOW_TO_MOVE, stopOldSpec_P_DONT_PICTURE_TWICE, stopOldSpec_P_DONT_SCAN_TWICE, stopOldSpec_P_BATTERY_SAFETY_OLD}
set StartNewSpecActions = {startNewSpec_P_ALWAYS_FLY_LOW, startNewSpec_P_FOLLOWING_ACTIONS, startNewSpec_P_NO_FOLLOW_BEFORE_SCAN, startNewSpec_P_HIGH_PRIORITY_TO_MISSION, startNewSpec_P_NEW_HOW_TO_MOVE, startNewSpec_P_DONT_SCAN_TWICE, startNewSpec_P_BATTERY_SAFETY_NEW}
set ReconfigureActions = {reconfigure_MISSION, reconfigure_BATTERY_COUNTER}

fluent AfterStopBeforeStart_P_ALWAYS_FLY_LOW = <StopOldSpecActions, startNewSpec_P_ALWAYS_FLY_LOW>
fluent AfterStopBeforeStart_P_FOLLOWING_ACTIONS = <StopOldSpecActions, startNewSpec_P_FOLLOWING_ACTIONS>
fluent AfterStopBeforeStart_P_NO_FOLLOW_BEFORE_SCAN = <StopOldSpecActions, startNewSpec_P_NO_FOLLOW_BEFORE_SCAN>
fluent AfterStopBeforeStart_P_HIGH_PRIORITY_TO_MISSION = <StopOldSpecActions, startNewSpec_P_HIGH_PRIORITY_TO_MISSION>
fluent AfterStopBeforeStart_P_NEW_HOW_TO_MOVE = <StopOldSpecActions, startNewSpec_P_NEW_HOW_TO_MOVE>
fluent AfterStopBeforeStart_P_DONT_SCAN_TWICE = <StopOldSpecActions, startNewSpec_P_DONT_SCAN_TWICE>
fluent AfterStopBeforeStart_P_BATTERY_SAFETY_NEW = <StopOldSpecActions, startNewSpec_P_BATTERY_SAFETY_NEW>
fluent AfterStopBeforeStart = <stopOldSpec, startNewSpec>

fluent Pending_StopOldSpec_P_HIGH_PRIORITY_TO_MISSION = <hotSwapIn, stopOldSpec_P_HIGH_PRIORITY_TO_MISSION>
fluent Pending_StopOldSpec_P_DONT_SCAN_TWICE = <hotSwapIn, stopOldSpec_P_DONT_SCAN_TWICE>
fluent Pending_StopOldSpec_P_ALWAYS_FLY_HIGH = <hotSwapIn, stopOldSpec_P_ALWAYS_FLY_HIGH>
fluent Pending_StopOldSpec_P_DETECTED_ACTIONS = <hotSwapIn, stopOldSpec_P_DETECTED_ACTIONS>
fluent Pending_StopOldSpec_P_HOW_TO_MOVE = <hotSwapIn, stopOldSpec_P_HOW_TO_MOVE>
fluent Pending_StopOldSpec_P_DONT_PICTURE_TWICE = <hotSwapIn, stopOldSpec_P_DONT_PICTURE_TWICE>
fluent Pending_StopOldSpec_P_BATTERY_SAFETY_OLD = <hotSwapIn, stopOldSpec_P_BATTERY_SAFETY_OLD>

fluent Pending_StartNewSpec_P_HIGH_PRIORITY_TO_MISSION = <hotSwapIn, startNewSpec_P_HIGH_PRIORITY_TO_MISSION>
fluent Pending_StartNewSpec_P_ALWAYS_FLY_LOW = <hotSwapIn, startNewSpec_P_ALWAYS_FLY_LOW>
fluent Pending_StartNewSpec_P_NO_FOLLOW_BEFORE_SCAN = <hotSwapIn, startNewSpec_P_NO_FOLLOW_BEFORE_SCAN>
fluent Pending_StartNewSpec_P_NEW_HOW_TO_MOVE = <hotSwapIn, startNewSpec_P_NEW_HOW_TO_MOVE>
fluent Pending_StartNewSpec_P_DONT_SCAN_TWICE = <hotSwapIn, startNewSpec_P_DONT_SCAN_TWICE>
fluent Pending_StartNewSpec_P_FOLLOWING_ACTIONS = <hotSwapIn, startNewSpec_P_FOLLOWING_ACTIONS>
fluent Pending_StartNewSpec_P_BATTERY_SAFETY_NEW = <hotSwapIn, startNewSpec_P_BATTERY_SAFETY_NEW>

fluent Pending_Reconfigure_MISSION = <hotSwapIn, reconfigure_MISSION>
fluent Pending_Reconfigure_BATTERY_COUNTER = <hotSwapIn, reconfigure_BATTERY_COUNTER>

// T1: 更新中であるならば，更新先制御器の制御可能事象を実行しない
assert AnyAction = (return2base || move || low || mid || high || scan || picture || takeoff || follow || weather)
ltl_property R1_P_ALWAYS_FLY_LOW = [](AfterStopBeforeStart_P_ALWAYS_FLY_LOW -> !AnyAction)
ltl_property R1_P_FOLLOWING_ACTIONS = [](AfterStopBeforeStart_P_FOLLOWING_ACTIONS -> !AnyAction)
ltl_property R1_P_NO_FOLLOW_BEFORE_SCAN = [](AfterStopBeforeStart_P_NO_FOLLOW_BEFORE_SCAN -> !AnyAction)
ltl_property R1_P_HIGH_PRIORITY_TO_MISSION = [](AfterStopBeforeStart_P_HIGH_PRIORITY_TO_MISSION -> !AnyAction)
ltl_property R1_P_NEW_HOW_TO_MOVE = [](AfterStopBeforeStart_P_NEW_HOW_TO_MOVE -> !AnyAction)
ltl_property R1_P_DONT_SCAN_TWICE = [](AfterStopBeforeStart_P_DONT_SCAN_TWICE -> !AnyAction)
ltl_property R1_P_BATTERY_SAFETY_NEW = [](AfterStopBeforeStart_P_BATTERY_SAFETY_NEW -> !AnyAction)
ltl_property R1_SFG = [](AfterStopBeforeStart -> !AnyAction)

// T2: 各環境モデルを更新（reconfigure）する前に，必ず該当のstopOldSpecとstartNewSpecを実施する
ltl_property R2_StopOldSpec_P_HIGH_PRIORITY_TO_MISSION = [](Pending_StopOldSpec_P_HIGH_PRIORITY_TO_MISSION -> (Pending_Reconfigure_MISSION && Pending_Reconfigure_BATTERY_COUNTER))
ltl_property R2_StopOldSpec_P_DONT_SCAN_TWICE = [](Pending_StopOldSpec_P_DONT_SCAN_TWICE -> (Pending_Reconfigure_MISSION && Pending_Reconfigure_BATTERY_COUNTER))
ltl_property R2_StopOldSpec_P_ALWAYS_FLY_HIGH = [](Pending_StopOldSpec_P_ALWAYS_FLY_HIGH -> (Pending_Reconfigure_MISSION && Pending_Reconfigure_BATTERY_COUNTER))
ltl_property R2_StopOldSpec_P_DETECTED_ACTIONS = [](Pending_StopOldSpec_P_DETECTED_ACTIONS -> (Pending_Reconfigure_MISSION && Pending_Reconfigure_BATTERY_COUNTER))
ltl_property R2_StopOldSpec_P_HOW_TO_MOVE = [](Pending_StopOldSpec_P_HOW_TO_MOVE -> (Pending_Reconfigure_MISSION && Pending_Reconfigure_BATTERY_COUNTER))
ltl_property R2_StopOldSpec_P_DONT_PICTURE_TWICE = [](Pending_StopOldSpec_P_DONT_PICTURE_TWICE -> (Pending_Reconfigure_MISSION && Pending_Reconfigure_BATTERY_COUNTER))
ltl_property R2_StopOldSpec_P_BATTERY_SAFETY_OLD = [](Pending_StopOldSpec_P_BATTERY_SAFETY_OLD -> (Pending_Reconfigure_MISSION && Pending_Reconfigure_BATTERY_COUNTER))

ltl_property R2_StartNewSpec_P_HIGH_PRIORITY_TO_MISSION = [](Pending_StartNewSpec_P_HIGH_PRIORITY_TO_MISSION -> (Pending_Reconfigure_MISSION && Pending_Reconfigure_BATTERY_COUNTER))
ltl_property R2_StartNewSpec_P_ALWAYS_FLY_LOW = [](Pending_StartNewSpec_P_ALWAYS_FLY_LOW -> (Pending_Reconfigure_MISSION && Pending_Reconfigure_BATTERY_COUNTER))
ltl_property R2_StartNewSpec_P_NO_FOLLOW_BEFORE_SCAN = [](Pending_StartNewSpec_P_NO_FOLLOW_BEFORE_SCAN -> (Pending_Reconfigure_MISSION && Pending_Reconfigure_BATTERY_COUNTER))
ltl_property R2_StartNewSpec_P_NEW_HOW_TO_MOVE = [](Pending_StartNewSpec_P_NEW_HOW_TO_MOVE -> (Pending_Reconfigure_MISSION && Pending_Reconfigure_BATTERY_COUNTER))
ltl_property R2_StartNewSpec_P_DONT_SCAN_TWICE = [](Pending_StartNewSpec_P_DONT_SCAN_TWICE -> (Pending_Reconfigure_MISSION && Pending_Reconfigure_BATTERY_COUNTER))
ltl_property R2_StartNewSpec_P_FOLLOWING_ACTIONS = [](Pending_StartNewSpec_P_FOLLOWING_ACTIONS -> (Pending_Reconfigure_MISSION && Pending_Reconfigure_BATTERY_COUNTER))
ltl_property R2_StartNewSpec_P_BATTERY_SAFETY_NEW = [](Pending_StartNewSpec_P_BATTERY_SAFETY_NEW -> (Pending_Reconfigure_MISSION && Pending_Reconfigure_BATTERY_COUNTER))

// ————————— NOT On-The-Fly —————————–

updatingController UpdCont_FG = {
oldController = EnvironmentAndController,
oldEnvironment = {MISSION, BATTERY_COUNTER},
newEnvironment = {NEW_MISSION, NEW_BATTERY_COUNTER},
mapRelation = {R_MISSION_FG, R_BATTERY_COUNTER_FG},
oldGoal = OldSpec,
newGoal = NewSpec,
nonblocking,
fine_grained
}
||UPDATE_CONTROLLER_FG = UpdCont_FG.

updatingController UpdCont_FG_R1 = {
oldController = EnvironmentAndController,
oldEnvironment = {MISSION, BATTERY_COUNTER},
newEnvironment = {NEW_MISSION, NEW_BATTERY_COUNTER},
mapRelation = {R_MISSION_FG, R_BATTERY_COUNTER_FG},
oldGoal = OldSpec,
newGoal = NewSpec,
transition = R1_P_ALWAYS_FLY_LOW,
transition = R1_P_FOLLOWING_ACTIONS,
transition = R1_P_NO_FOLLOW_BEFORE_SCAN,
transition = R1_P_HIGH_PRIORITY_TO_MISSION,
transition = R1_P_NEW_HOW_TO_MOVE,
transition = R1_P_DONT_SCAN_TWICE,
transition = R1_P_BATTERY_SAFETY_NEW,
nonblocking,
fine_grained
}
||UPDATE_CONTROLLER_FG_R1 = UpdCont_FG_R1.

updatingController UpdCont_FG_R2 = {
oldController = EnvironmentAndController,
oldEnvironment = {MISSION, BATTERY_COUNTER},
newEnvironment = {NEW_MISSION, NEW_BATTERY_COUNTER},
mapRelation = {R_MISSION_FG, R_BATTERY_COUNTER_FG},
oldGoal = OldSpec,
newGoal = NewSpec,
transition = R2_StopOldSpec_P_HIGH_PRIORITY_TO_MISSION,
transition = R2_StopOldSpec_P_DONT_SCAN_TWICE,
transition = R2_StopOldSpec_P_ALWAYS_FLY_HIGH,
transition = R2_StopOldSpec_P_DETECTED_ACTIONS,
transition = R2_StopOldSpec_P_HOW_TO_MOVE,
transition = R2_StopOldSpec_P_DONT_PICTURE_TWICE,
transition = R2_StopOldSpec_P_BATTERY_SAFETY_OLD,
transition = R2_StartNewSpec_P_HIGH_PRIORITY_TO_MISSION,
transition = R2_StartNewSpec_P_ALWAYS_FLY_LOW,
transition = R2_StartNewSpec_P_NO_FOLLOW_BEFORE_SCAN,
transition = R2_StartNewSpec_P_NEW_HOW_TO_MOVE,
transition = R2_StartNewSpec_P_DONT_SCAN_TWICE,
transition = R2_StartNewSpec_P_FOLLOWING_ACTIONS,
transition = R2_StartNewSpec_P_BATTERY_SAFETY_NEW,
nonblocking,
fine_grained
}
||UPDATE_CONTROLLER_FG_R2 = UpdCont_FG_R2.

updatingController UpdCont_SFG = {
oldController = EnvironmentAndController,
oldEnvironment = {MISSION, BATTERY_COUNTER},
newEnvironment = {NEW_MISSION, NEW_BATTERY_COUNTER},
mapRelation = {R_MISSION_FG, R_BATTERY_COUNTER_FG},
oldGoal = OldSpec,
newGoal = NewSpec,
nonblocking,
selective_fine_grained
}
||UPDATE_CONTROLLER_SFG = UpdCont_SFG.

updatingController UpdCont_SFG_R1 = {
oldController = EnvironmentAndController,
oldEnvironment = {MISSION, BATTERY_COUNTER},
newEnvironment = {NEW_MISSION, NEW_BATTERY_COUNTER},
mapRelation = {R_MISSION_FG, R_BATTERY_COUNTER_FG},
oldGoal = OldSpec,
newGoal = NewSpec,
transition = R1_SFG,
nonblocking,
selective_fine_grained
}
||UPDATE_CONTROLLER_SFG_R1 = UpdCont_SFG_R1.

updatingController UpdCont_SFG_R2 = {
oldController = EnvironmentAndController,
oldEnvironment = {MISSION, BATTERY_COUNTER},
newEnvironment = {NEW_MISSION, NEW_BATTERY_COUNTER},
mapRelation = {R_MISSION_FG, R_BATTERY_COUNTER_FG},
oldGoal = OldSpec,
newGoal = NewSpec,
transition = R2_StopOldSpec_P_HIGH_PRIORITY_TO_MISSION,
transition = R2_StopOldSpec_P_DONT_SCAN_TWICE,
transition = R2_StopOldSpec_P_ALWAYS_FLY_HIGH,
transition = R2_StopOldSpec_P_DETECTED_ACTIONS,
transition = R2_StopOldSpec_P_HOW_TO_MOVE,
transition = R2_StopOldSpec_P_DONT_PICTURE_TWICE,
transition = R2_StopOldSpec_P_BATTERY_SAFETY_OLD,
transition = R2_StartNewSpec_P_HIGH_PRIORITY_TO_MISSION,
transition = R2_StartNewSpec_P_ALWAYS_FLY_LOW,
transition = R2_StartNewSpec_P_NO_FOLLOW_BEFORE_SCAN,
transition = R2_StartNewSpec_P_NEW_HOW_TO_MOVE,
transition = R2_StartNewSpec_P_DONT_SCAN_TWICE,
transition = R2_StartNewSpec_P_FOLLOWING_ACTIONS,
transition = R2_StartNewSpec_P_BATTERY_SAFETY_NEW,
nonblocking,
selective_fine_grained
}
||UPDATE_CONTROLLER_SFG_R2 = UpdCont_SFG_R2.

// ————————— Apply On-The-Fly —————————–

updatingController UpdCont_OTF_FG = {
oldController = EnvironmentAndController,
oldEnvironment = {MISSION, BATTERY_COUNTER},
newEnvironment = {NEW_MISSION, NEW_BATTERY_COUNTER},
mapRelation = {R_MISSION_FG, R_BATTERY_COUNTER_FG},
oldGoal = OldSpec,
newGoal = NewSpec,
nonblocking,
on_the_fly,
fine_grained
}
||UPDATE_CONTROLLER_OTF_FG = UpdCont_OTF_FG.

updatingController UpdCont_OTF_FG_R1 = {
oldController = EnvironmentAndController,
oldEnvironment = {MISSION, BATTERY_COUNTER},
newEnvironment = {NEW_MISSION, NEW_BATTERY_COUNTER},
mapRelation = {R_MISSION_FG, R_BATTERY_COUNTER_FG},
oldGoal = OldSpec,
newGoal = NewSpec,
transition = R1_P_ALWAYS_FLY_LOW,
transition = R1_P_FOLLOWING_ACTIONS,
transition = R1_P_NO_FOLLOW_BEFORE_SCAN,
transition = R1_P_HIGH_PRIORITY_TO_MISSION,
transition = R1_P_NEW_HOW_TO_MOVE,
transition = R1_P_DONT_SCAN_TWICE,
transition = R1_P_BATTERY_SAFETY_NEW,
nonblocking,
on_the_fly,
fine_grained
}
||UPDATE_CONTROLLER_OTF_FG_R1 = UpdCont_OTF_FG_R1.

updatingController UpdCont_OTF_FG_R2 = {
oldController = EnvironmentAndController,
oldEnvironment = {MISSION, BATTERY_COUNTER},
newEnvironment = {NEW_MISSION, NEW_BATTERY_COUNTER},
mapRelation = {R_MISSION_FG, R_BATTERY_COUNTER_FG},
oldGoal = OldSpec,
newGoal = NewSpec,
transition = R2_StopOldSpec_P_HIGH_PRIORITY_TO_MISSION,
transition = R2_StopOldSpec_P_DONT_SCAN_TWICE,
transition = R2_StopOldSpec_P_ALWAYS_FLY_HIGH,
transition = R2_StopOldSpec_P_DETECTED_ACTIONS,
transition = R2_StopOldSpec_P_HOW_TO_MOVE,
transition = R2_StopOldSpec_P_DONT_PICTURE_TWICE,
transition = R2_StopOldSpec_P_BATTERY_SAFETY_OLD,
transition = R2_StartNewSpec_P_HIGH_PRIORITY_TO_MISSION,
transition = R2_StartNewSpec_P_ALWAYS_FLY_LOW,
transition = R2_StartNewSpec_P_NO_FOLLOW_BEFORE_SCAN,
transition = R2_StartNewSpec_P_NEW_HOW_TO_MOVE,
transition = R2_StartNewSpec_P_DONT_SCAN_TWICE,
transition = R2_StartNewSpec_P_FOLLOWING_ACTIONS,
transition = R2_StartNewSpec_P_BATTERY_SAFETY_NEW,
nonblocking,
on_the_fly,
fine_grained
}
||UPDATE_CONTROLLER_OTF_FG_R2 = UpdCont_OTF_FG_R2.

updatingController UpdCont_OTF_SFG = {
oldController = EnvironmentAndController,
oldEnvironment = {MISSION, BATTERY_COUNTER},
newEnvironment = {NEW_MISSION, NEW_BATTERY_COUNTER},
mapRelation = {R_MISSION_FG, R_BATTERY_COUNTER_FG},
oldGoal = OldSpec,
