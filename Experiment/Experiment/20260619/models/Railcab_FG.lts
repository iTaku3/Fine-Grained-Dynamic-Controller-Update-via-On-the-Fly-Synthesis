// -----------------------------COMMENTS-------------------------------

// - To execute the solution for update controllers select in the dropdown menu 
// the "UPDATE_CONTROLLER" label, and then press the compose button (||).
// - In the section of UPDATING CONTROLLER SPEC, in this file, you can spec
// different transition requeriments presented in the paper.
// - You can animate the controller obtained pressing the blue A in the top bar
// - After composing, you can validate that the controller obtained satisfy 
// each updating controller goal formula by modelchecking.

// ---------------------------ENVIRONMENTS-----------------------------

set ControllableActionsOld = {requestEnter, brake, emergencyBrake, idle_c}
set ControllableActionsNew = {requestEnter, brake, emergencyBrake, idle_c, checkCrossingStatus}
set AlphabetOld = {ControllableActionsOld, endOfTS, lastBrake, lastEmergencyBrake, noReturn,enterCrossing, enterAllowed[0..1]}
set AlphabetNew = {ControllableActionsNew, endOfTS, lastBrake, lastEmergencyBrake, noReturn,enterCrossing, enterAllowed[0..1], working, notWorking, approachingCrossing}

//oldEnvironment
MILESTONES_OLD = (endOfTS -> ENDOFTS),
ENDOFTS = (lastBrake -> LB | {brake,emergencyBrake} -> MILESTONES_OLD),
LB = (lastEmergencyBrake -> LEB | {brake, emergencyBrake} -> MILESTONES_OLD),
LEB = (noReturn -> NR | {brake, emergencyBrake} -> MILESTONES_OLD),
NR = (enterCrossing -> MILESTONES_OLD).

REQUEST_ATOMIC_OLD = (requestEnter -> RESPONSE | {AlphabetOld\ControllableActionsOld}\{enterAllowed[0..1]} -> REQUEST_ATOMIC_OLD),
RESPONSE = (enterAllowed[0..1] -> REQUEST_ATOMIC_OLD).

TURNS_OLD = ({AlphabetOld\ControllableActionsOld}\{enterAllowed[0..1],enterCrossing} -> TURNS2 | enterCrossing -> TURNS_OLD),
TURNS2 = (ControllableActionsOld -> TURNS_OLD).

ANOTHER_REQUEST_OLD = (AlphabetOld -> ANOTHER_REQUEST_OLD).

//NewEnvironment
MILESTONES_NEW = (endOfTS -> ENDOFTS),
ENDOFTS = (approachingCrossing -> AC | {brake,emergencyBrake} -> MILESTONES_NEW),
AC = (lastBrake -> LB| {brake,emergencyBrake} -> MILESTONES_NEW),
//	LB = (lastEmergencyBrake -> LEB | {brake, enterCrossing} -> MILESTONES_NEW),
//	LEB = (noReturn -> NR | {brake, enterCrossing} -> MILESTONES_NEW),
LB = (lastEmergencyBrake -> LEB | {brake, emergencyBrake} -> MILESTONES_NEW),
LEB = (noReturn -> NR | {brake, emergencyBrake} -> MILESTONES_NEW),
NR = (enterCrossing -> MILESTONES_NEW).

REQUEST_ATOMIC_NEW = (requestEnter -> RESPONSE | {AlphabetNew\ControllableActionsNew}\{enterAllowed[0..1]} -> REQUEST_ATOMIC_NEW),
RESPONSE = (enterAllowed[0..1] -> REQUEST_ATOMIC_NEW).

TURNS_NEW = ({AlphabetNew\ControllableActionsNew}\{working, notWorking, enterAllowed[0..1],enterCrossing} -> TURNS2 | enterCrossing -> TURNS_NEW),
TURNS2 = (ControllableActionsNew -> TURNS_NEW).

ANOTHER_REQUEST = (checkCrossingStatus -> ANSWER | AlphabetNew\{checkCrossingStatus,working,notWorking}-> ANOTHER_REQUEST),
ANSWER 		    = ({working,notWorking} -> ANOTHER_REQUEST).
//ANOTHER_REQUEST = (checkCrossingStatus -> ANSWER | {AlphabetNew\ControllableActionsNew}\{working,notWorking}-> ANOTHER_REQUEST),

||OldEnvironment = (MILESTONES_OLD || REQUEST_ATOMIC_OLD || TURNS_OLD).
||NewEnvironment = (MILESTONES_NEW || REQUEST_ATOMIC_NEW || TURNS_NEW || ANOTHER_REQUEST).

relation R_MILESTONES = {MILESTONES_OLD@MILESTONES_OLD = reconfigure -> MILESTONES_NEW@MILESTONES_NEW,
						ENDOFTS@MILESTONES_OLD = reconfigure -> ENDOFTS@MILESTONES_NEW,
						ENDOFTS@MILESTONES_OLD = reconfigure -> AC@MILESTONES_NEW,
						LB@MILESTONES_OLD = reconfigure -> LB@MILESTONES_NEW,
						LEB@MILESTONES_OLD = reconfigure -> approachingCrossing -> LEB@MILESTONES_NEW,
						NR@MILESTONES_OLD = reconfigure -> approachingCrossing -> NR@MILESTONES_NEW}

relation R_MILESTONES_FG = {MILESTONES_OLD@MILESTONES_OLD = reconfigure_MILESTONES -> MILESTONES_NEW@MILESTONES_NEW,
						ENDOFTS@MILESTONES_OLD = reconfigure_MILESTONES -> ENDOFTS@MILESTONES_NEW,
						ENDOFTS@MILESTONES_OLD = reconfigure_MILESTONES -> AC@MILESTONES_NEW,
						LB@MILESTONES_OLD = reconfigure_MILESTONES -> LB@MILESTONES_NEW,
						LEB@MILESTONES_OLD = reconfigure_MILESTONES -> approachingCrossing -> LEB@MILESTONES_NEW,
						NR@MILESTONES_OLD = reconfigure_MILESTONES -> approachingCrossing -> NR@MILESTONES_NEW}

relation R_REQUEST_ATOMIC = {REQUEST_ATOMIC_OLD@REQUEST_ATOMIC_OLD = reconfigure -> REQUEST_ATOMIC_NEW@REQUEST_ATOMIC_NEW,
							RESPONSE@REQUEST_ATOMIC_OLD = reconfigure -> RESPONSE@REQUEST_ATOMIC_NEW}

relation R_REQUEST_ATOMIC_FG = {REQUEST_ATOMIC_OLD@REQUEST_ATOMIC_OLD = reconfigure_REQUEST_ATOMIC -> REQUEST_ATOMIC_NEW@REQUEST_ATOMIC_NEW,
							RESPONSE@REQUEST_ATOMIC_OLD = reconfigure_REQUEST_ATOMIC -> RESPONSE@REQUEST_ATOMIC_NEW}

relation R_TURNS = {TURNS_OLD@TURNS_OLD = reconfigure -> TURNS_NEW@TURNS_NEW,
					TURNS2@TURNS_OLD = reconfigure -> TURNS2@TURNS_NEW}

relation R_TURNS_FG = {TURNS_OLD@TURNS_OLD = reconfigure_TURNS -> TURNS_NEW@TURNS_NEW,
					TURNS2@TURNS_OLD = reconfigure_TURNS -> TURNS2@TURNS_NEW}

relation R_ANOTHER_REQUEST = {ANOTHER_REQUEST_OLD@ANOTHER_REQUEST_OLD = reconfigure -> ANOTHER_REQUEST@ANOTHER_REQUEST}

relation R_ANOTHER_REQUEST_FG = {ANOTHER_REQUEST_OLD@ANOTHER_REQUEST_OLD = reconfigure_ANOTHER_REQUEST -> ANOTHER_REQUEST@ANOTHER_REQUEST}

map MAP_MILESTONES = {MILESTONES_OLD, MILESTONES_NEW, R_MILESTONES}.
map MAP_REQUEST_ATOMIC = {REQUEST_ATOMIC_OLD, REQUEST_ATOMIC_NEW, R_REQUEST_ATOMIC}.
map MAP_TURNS = {TURNS_OLD, TURNS_NEW, R_TURNS}.
map MAP_ANOTHER_REQUEST = {ANOTHER_REQUEST_OLD, ANOTHER_REQUEST, R_ANOTHER_REQUEST}.

||OldEnv = (MILESTONES_OLD || REQUEST_ATOMIC_OLD || TURNS_OLD || ANOTHER_REQUEST_OLD).
||NewEnv = (MILESTONES_NEW || REQUEST_ATOMIC_NEW || TURNS_NEW || ANOTHER_REQUEST).
||MapEnv = (MAP_MILESTONES || MAP_REQUEST_ATOMIC || MAP_TURNS || MAP_ANOTHER_REQUEST).

// ---------------------------OLD CONTROLLER SPEC-----------------------------

fluent RequestedOnce = <{requestEnter},{endOfTS}>
fluent CantEnter = <{enterAllowed[0]},{endOfTS}>
fluent LastEmergencyBrake = <lastEmergencyBrake, endOfTS>
fluent NoReturn = <noReturn,endOfTS>
fluent ApproachingCrossingHappen = <{approachingCrossing},{endOfTS}>

fluent AskedWorkingOnce = <{checkCrossingStatus},{endOfTS}>
fluent NotWorking = <notWorking, endOfTS>

assert NOT_CRASH = !((CantEnter && NoReturn) || (!RequestedOnce && NoReturn))
assert BRAKE_DURING_LASTBRAKE			= (brake -> !LastEmergencyBrake)
assert EBRAKE_DURING_ELASTBRAKE  		= (emergencyBrake -> !NoReturn)
assert BRAKE_ONLY_IF_IM_NOT_ALLOWED		= (brake -> CantEnter)
assert EBRAKE_ONLY_IF_IM_NOT_ALLOWED	= (emergencyBrake -> CantEnter)
ltl_property P_NOT_CRASH						= []NOT_CRASH
ltl_property P_BRAKE_DURING_LASTBRAKE			= []BRAKE_DURING_LASTBRAKE
ltl_property P_EBRAKE_DURING_ELASTBRAKE  		= []EBRAKE_DURING_ELASTBRAKE
ltl_property P_BRAKE_ONLY_IF_IM_NOT_ALLOWED		= []BRAKE_ONLY_IF_IM_NOT_ALLOWED
ltl_property P_EBRAKE_ONLY_IF_IM_NOT_ALLOWED	= []EBRAKE_ONLY_IF_IM_NOT_ALLOWED

controllerSpec OldSpec = {
    safety = {P_BRAKE_DURING_LASTBRAKE, P_EBRAKE_DURING_ELASTBRAKE, P_NOT_CRASH, 
			P_BRAKE_ONLY_IF_IM_NOT_ALLOWED, P_EBRAKE_ONLY_IF_IM_NOT_ALLOWED}
    controllable = {ControllableActionsOld}
}

controller ||OldController = OldEnvironment~{OldSpec}.
||EnvironmentAndController = (OldController || OldEnvironment).

controller ||OldCont = OldEnv~{OldSpec}.
||OldEnvAndCont = (OldCont || OldEnv).

// ---------------------------NEW CONTROLLER SPEC-----------------------------

assert NEW_NOT_CRASH = !((CantEnter && NoReturn) || ((!RequestedOnce || !AskedWorkingOnce) && NoReturn) || (NotWorking && NoReturn))
assert BRAKE_IF_SOMETHING_BAD			= (brake -> (CantEnter || NotWorking))
assert EBRAKE_IF_SOMETHING_BAD			= (emergencyBrake -> (CantEnter || NotWorking))
assert CHECK_STATUS_AFTER_APPROACHING_CROSSING = (checkCrossingStatus -> (ApproachingCrossingHappen && !LastEmergencyBrake))
assert CHECK_STATUS_BEFORE_LAST_EMERGENCY_BRAKE = (LastEmergencyBrake -> (!checkCrossingStatus))
ltl_property P_BRAKE_IF_SOMETHING_BAD	    = []BRAKE_IF_SOMETHING_BAD
ltl_property P_EBRAKE_IF_SOMETHING_BAD	    = []EBRAKE_IF_SOMETHING_BAD
ltl_property P_NEW_NOT_CRASH 				= []NEW_NOT_CRASH
ltl_property P_CHECK_STATUS_AFTER_APPROACHING_CROSSING = []CHECK_STATUS_AFTER_APPROACHING_CROSSING
ltl_property P_CHECK_STATUS_BEFORE_LAST_EMERGENCY_BRAKE = []CHECK_STATUS_BEFORE_LAST_EMERGENCY_BRAKE

controllerSpec NewSpec = {
    safety = {P_BRAKE_DURING_LASTBRAKE, P_EBRAKE_DURING_ELASTBRAKE, P_NEW_NOT_CRASH, P_CHECK_STATUS_BEFORE_LAST_EMERGENCY_BRAKE,
			P_BRAKE_IF_SOMETHING_BAD, P_EBRAKE_IF_SOMETHING_BAD, P_CHECK_STATUS_AFTER_APPROACHING_CROSSING}
    controllable = {ControllableActionsNew}
}

controller ||NewController = NewEnvironment~{NewSpec}.
||NewControllerAndNewEnvironment = (NewController || NewEnvironment).

// ---------------------------UPDATING CONTROLLER SPEC-----------------------------

set StopOldSpecActions = {stopOldSpec_P_BRAKE_DURING_LASTBRAKE, stopOldSpec_P_EBRAKE_DURING_ELASTBRAKE, stopOldSpec_P_NOT_CRASH, stopOldSpec_P_BRAKE_ONLY_IF_IM_NOT_ALLOWED, stopOldSpec_P_EBRAKE_ONLY_IF_IM_NOT_ALLOWED}
set StartNewSpecActions = {startNewSpec_P_BRAKE_DURING_LASTBRAKE, startNewSpec_P_EBRAKE_DURING_ELASTBRAKE, startNewSpec_P_NEW_NOT_CRASH, startNewSpec_P_CHECK_STATUS_BEFORE_LAST_EMERGENCY_BRAKE, startNewSpec_P_BRAKE_IF_SOMETHING_BAD, startNewSpec_P_EBRAKE_IF_SOMETHING_BAD, startNewSpec_P_CHECK_STATUS_AFTER_APPROACHING_CROSSING}
set ReconfigureActions = {reconfigure_MILESTONES, reconfigure_REQUEST_ATOMIC, reconfigure_TURNS,  reconfigure_ANOTHER_REQUEST}

fluent Updating = <hotSwapIn,hotSwapOut>
fluent Done_StopOldSpec_P_BRAKE_DURING_LASTBRAKE = <stopOldSpec_P_BRAKE_DURING_LASTBRAKE,hotSwapOut>
fluent Done_StopOldSpec_P_EBRAKE_DURING_ELASTBRAKE = <stopOldSpec_P_EBRAKE_DURING_ELASTBRAKE,hotSwapOut>
fluent Done_StopOldSpec_P_NOT_CRASH = <stopOldSpec_P_NOT_CRASH,hotSwapOut>
fluent Done_StopOldSpec_P_BRAKE_ONLY_IF_IM_NOT_ALLOWED = <stopOldSpec_P_BRAKE_ONLY_IF_IM_NOT_ALLOWED,hotSwapOut>
fluent Done_StopOldSpec_P_EBRAKE_ONLY_IF_IM_NOT_ALLOWED = <stopOldSpec_P_EBRAKE_ONLY_IF_IM_NOT_ALLOWED,hotSwapOut>
fluent Done_StartNewSpec_P_BRAKE_DURING_LASTBRAKE = <startNewSpec_P_BRAKE_DURING_LASTBRAKE,hotSwapOut>
fluent Done_StartNewSpec_P_EBRAKE_DURING_ELASTBRAKE = <startNewSpec_P_EBRAKE_DURING_ELASTBRAKE,hotSwapOut>
fluent Done_StartNewSpec_P_NEW_NOT_CRASH = <startNewSpec_P_NEW_NOT_CRASH,hotSwapOut>
fluent Done_StartNewSpec_P_CHECK_STATUS_BEFORE_LAST_EMERGENCY_BRAKE = <startNewSpec_P_CHECK_STATUS_BEFORE_LAST_EMERGENCY_BRAKE,hotSwapOut>
fluent Done_StartNewSpec_P_BRAKE_IF_SOMETHING_BAD = <startNewSpec_P_BRAKE_IF_SOMETHING_BAD,hotSwapOut>
fluent Done_StartNewSpec_P_EBRAKE_IF_SOMETHING_BAD = <startNewSpec_P_EBRAKE_IF_SOMETHING_BAD,hotSwapOut>
fluent Done_StartNewSpec_P_CHECK_STATUS_AFTER_APPROACHING_CROSSING = <startNewSpec_P_CHECK_STATUS_AFTER_APPROACHING_CROSSING,hotSwapOut>
fluent Done_Reconfigure_MILESTONES = <reconfigure_MILESTONES,hotSwapOut>
fluent Done_Reconfigure_REQUEST_ATOMIC = <reconfigure_REQUEST_ATOMIC,hotSwapOut>
fluent Done_Reconfigure_TURNS = <reconfigure_TURNS,hotSwapOut>
fluent Done_Reconfigure_ANOTHER_REQUEST = <reconfigure_ANOTHER_REQUEST,hotSwapOut>

// T1: 更新中であるならば，更新先制御器の制御可能事象を実行しない
//ltl_property T1 = [](Updating -> !{validateTOR, validateDSD1, validateQA, validateGF1, reviewTOR, reviewDSD1, readyTOR,  readyDSD1})
ltl_property R1 = []({stopOldSpec_P_BRAKE_DURING_LASTBRAKE, stopOldSpec_P_EBRAKE_DURING_ELASTBRAKE, stopOldSpec_P_NOT_CRASH, stopOldSpec_P_BRAKE_ONLY_IF_IM_NOT_ALLOWED, stopOldSpec_P_EBRAKE_ONLY_IF_IM_NOT_ALLOWED} -> X(!{requestEnter, brake, emergencyBrake, idle_c, checkCrossingStatus} W {startNewSpec_P_BRAKE_DURING_LASTBRAKE, startNewSpec_P_EBRAKE_DURING_ELASTBRAKE, startNewSpec_P_NEW_NOT_CRASH, startNewSpec_P_CHECK_STATUS_BEFORE_LAST_EMERGENCY_BRAKE, startNewSpec_P_BRAKE_IF_SOMETHING_BAD, startNewSpec_P_EBRAKE_IF_SOMETHING_BAD, startNewSpec_P_CHECK_STATUS_AFTER_APPROACHING_CROSSING}))

// T2: 各環境モデルを更新（reconfigure）する前に，必ず該当のstopOldSpecとstartNewSpecを実施する
ltl_property R2_StopOldSpec_P_BRAKE_DURING_LASTBRAKE = []((Done_Reconfigure_MILESTONES || Done_Reconfigure_REQUEST_ATOMIC || Done_Reconfigure_TURNS) -> Done_StopOldSpec_P_BRAKE_DURING_LASTBRAKE)
ltl_property R2_StopOldSpec_P_EBRAKE_DURING_ELASTBRAKE = []((Done_Reconfigure_MILESTONES || Done_Reconfigure_REQUEST_ATOMIC || Done_Reconfigure_TURNS) -> Done_StopOldSpec_P_EBRAKE_DURING_ELASTBRAKE)
ltl_property R2_StopOldSpec_P_BRAKE_ONLY_IF_IM_NOT_ALLOWED = []((Done_Reconfigure_MILESTONES || Done_Reconfigure_REQUEST_ATOMIC || Done_Reconfigure_TURNS) -> Done_StopOldSpec_P_BRAKE_ONLY_IF_IM_NOT_ALLOWED)
ltl_property R2_StopOldSpec_P_NOT_CRASH = []((Done_Reconfigure_MILESTONES || Done_Reconfigure_REQUEST_ATOMIC || Done_Reconfigure_TURNS) -> Done_StopOldSpec_P_NOT_CRASH)
ltl_property R2_StopOldSpec_P_EBRAKE_ONLY_IF_IM_NOT_ALLOWED = []((Done_Reconfigure_MILESTONES || Done_Reconfigure_REQUEST_ATOMIC || Done_Reconfigure_TURNS) -> Done_StopOldSpec_P_EBRAKE_ONLY_IF_IM_NOT_ALLOWED)
ltl_property R2_StartNewSpec_P_EBRAKE_DURING_ELASTBRAKE = []((Done_Reconfigure_MILESTONES || Done_Reconfigure_REQUEST_ATOMIC || Done_Reconfigure_TURNS || Done_Reconfigure_ANOTHER_REQUEST) -> Done_StartNewSpec_P_EBRAKE_DURING_ELASTBRAKE)
ltl_property R2_StartNewSpec_P_EBRAKE_IF_SOMETHING_BAD = []((Done_Reconfigure_MILESTONES || Done_Reconfigure_REQUEST_ATOMIC || Done_Reconfigure_TURNS || Done_Reconfigure_ANOTHER_REQUEST) -> Done_StartNewSpec_P_EBRAKE_IF_SOMETHING_BAD)
ltl_property R2_StartNewSpec_P_CHECK_STATUS_AFTER_APPROACHING_CROSSING = []((Done_Reconfigure_MILESTONES || Done_Reconfigure_REQUEST_ATOMIC || Done_Reconfigure_TURNS || Done_Reconfigure_ANOTHER_REQUEST) -> Done_StartNewSpec_P_CHECK_STATUS_AFTER_APPROACHING_CROSSING)
ltl_property R2_StartNewSpec_P_BRAKE_DURING_LASTBRAKE = []((Done_Reconfigure_MILESTONES || Done_Reconfigure_REQUEST_ATOMIC || Done_Reconfigure_TURNS || Done_Reconfigure_ANOTHER_REQUEST) -> Done_StartNewSpec_P_BRAKE_DURING_LASTBRAKE)
ltl_property R2_StartNewSpec_P_BRAKE_IF_SOMETHING_BAD = []((Done_Reconfigure_MILESTONES || Done_Reconfigure_REQUEST_ATOMIC || Done_Reconfigure_TURNS || Done_Reconfigure_ANOTHER_REQUEST) -> Done_StartNewSpec_P_BRAKE_IF_SOMETHING_BAD)
ltl_property R2_StartNewSpec_P_NEW_NOT_CRASH = []((Done_Reconfigure_MILESTONES || Done_Reconfigure_REQUEST_ATOMIC || Done_Reconfigure_TURNS || Done_Reconfigure_ANOTHER_REQUEST) -> Done_StartNewSpec_P_NEW_NOT_CRASH)
ltl_property R2_StartNewSpec_P_CHECK_STATUS_BEFORE_LAST_EMERGENCY_BRAKE = []((Done_Reconfigure_MILESTONES || Done_Reconfigure_REQUEST_ATOMIC || Done_Reconfigure_TURNS || Done_Reconfigure_ANOTHER_REQUEST) -> Done_StartNewSpec_P_CHECK_STATUS_BEFORE_LAST_EMERGENCY_BRAKE)

// --------------------------- NOT On-The-Fly -----------------------------

updatingController UpdCont_FG = {
    oldController = OldEnvAndCont,
	oldEnvironment = {MILESTONES_OLD, REQUEST_ATOMIC_OLD, TURNS_OLD, ANOTHER_REQUEST_OLD},
	newEnvironment = {MILESTONES_NEW, REQUEST_ATOMIC_NEW, TURNS_NEW, ANOTHER_REQUEST},
	mapRelation = {R_MILESTONES_FG, R_REQUEST_ATOMIC_FG, R_TURNS_FG, R_ANOTHER_REQUEST_FG},
    oldGoal = OldSpec,
    newGoal = NewSpec,
	nonblocking,
	fine_grained
}
||UPDATE_CONTROLLER_FG = UpdCont_FG.

updatingController UpdCont_FG_R1 = {
    oldController = OldEnvAndCont,
	oldEnvironment = {MILESTONES_OLD, REQUEST_ATOMIC_OLD, TURNS_OLD, ANOTHER_REQUEST_OLD},
	newEnvironment = {MILESTONES_NEW, REQUEST_ATOMIC_NEW, TURNS_NEW, ANOTHER_REQUEST},
	mapRelation = {R_MILESTONES_FG, R_REQUEST_ATOMIC_FG, R_TURNS_FG, R_ANOTHER_REQUEST_FG},
    oldGoal = OldSpec,
    newGoal = NewSpec,
	transition = R1,
	nonblocking,
	fine_grained
}
||UPDATE_CONTROLLER_FG_R1 = UpdCont_FG_R1.

updatingController UpdCont_FG_R2 = {
    oldController = OldEnvAndCont,
	oldEnvironment = {MILESTONES_OLD, REQUEST_ATOMIC_OLD, TURNS_OLD, ANOTHER_REQUEST_OLD},
	newEnvironment = {MILESTONES_NEW, REQUEST_ATOMIC_NEW, TURNS_NEW, ANOTHER_REQUEST},
	mapRelation = {R_MILESTONES_FG, R_REQUEST_ATOMIC_FG, R_TURNS_FG, R_ANOTHER_REQUEST_FG},
    oldGoal = OldSpec,
    newGoal = NewSpec,
	transition = R2_StopOldSpec_P_BRAKE_DURING_LASTBRAKE,
	transition = R2_StopOldSpec_P_EBRAKE_DURING_ELASTBRAKE,
	transition = R2_StopOldSpec_P_BRAKE_ONLY_IF_IM_NOT_ALLOWED,
	transition = R2_StopOldSpec_P_NOT_CRASH,
	transition = R2_StopOldSpec_P_EBRAKE_ONLY_IF_IM_NOT_ALLOWED,
	transition = R2_StartNewSpec_P_EBRAKE_DURING_ELASTBRAKE,
	transition = R2_StartNewSpec_P_EBRAKE_IF_SOMETHING_BAD,
	transition = R2_StartNewSpec_P_CHECK_STATUS_AFTER_APPROACHING_CROSSING,
	transition = R2_StartNewSpec_P_BRAKE_DURING_LASTBRAKE,
	transition = R2_StartNewSpec_P_BRAKE_IF_SOMETHING_BAD,
	transition = R2_StartNewSpec_P_NEW_NOT_CRASH,
	transition = R2_StartNewSpec_P_CHECK_STATUS_BEFORE_LAST_EMERGENCY_BRAKE,
	nonblocking,
	fine_grained
}
||UPDATE_CONTROLLER_FG_R2 = UpdCont_FG_R2.

updatingController UpdCont_SFG = {
    oldController = OldEnvAndCont,
	oldEnvironment = {MILESTONES_OLD, REQUEST_ATOMIC_OLD, TURNS_OLD, ANOTHER_REQUEST_OLD},
	newEnvironment = {MILESTONES_NEW, REQUEST_ATOMIC_NEW, TURNS_NEW, ANOTHER_REQUEST},
	mapRelation = {R_MILESTONES_FG, R_REQUEST_ATOMIC_FG, R_TURNS_FG, R_ANOTHER_REQUEST_FG},
    oldGoal = OldSpec,
    newGoal = NewSpec,
	nonblocking,
	selective_fine_grained
}
||UPDATE_CONTROLLER_SFG = UpdCont_SFG.

updatingController UpdCont_SFG_R1 = {
    oldController = OldEnvAndCont,
	oldEnvironment = {MILESTONES_OLD, REQUEST_ATOMIC_OLD, TURNS_OLD, ANOTHER_REQUEST_OLD},
	newEnvironment = {MILESTONES_NEW, REQUEST_ATOMIC_NEW, TURNS_NEW, ANOTHER_REQUEST},
	mapRelation = {R_MILESTONES_FG, R_REQUEST_ATOMIC_FG, R_TURNS_FG, R_ANOTHER_REQUEST_FG},
    oldGoal = OldSpec,
    newGoal = NewSpec,
	transition = R1,
	nonblocking,
	selective_fine_grained
}
||UPDATE_CONTROLLER_SFG_R1 = UpdCont_SFG_R1.

updatingController UpdCont_SFG_R2 = {
    oldController = OldEnvAndCont,
	oldEnvironment = {MILESTONES_OLD, REQUEST_ATOMIC_OLD, TURNS_OLD, ANOTHER_REQUEST_OLD},
	newEnvironment = {MILESTONES_NEW, REQUEST_ATOMIC_NEW, TURNS_NEW, ANOTHER_REQUEST},
	mapRelation = {R_MILESTONES_FG, R_REQUEST_ATOMIC_FG, R_TURNS_FG, R_ANOTHER_REQUEST_FG},
    oldGoal = OldSpec,
    newGoal = NewSpec,
	transition = R2_StopOldSpec_P_BRAKE_DURING_LASTBRAKE,
	transition = R2_StopOldSpec_P_EBRAKE_DURING_ELASTBRAKE,
	transition = R2_StopOldSpec_P_BRAKE_ONLY_IF_IM_NOT_ALLOWED,
	transition = R2_StopOldSpec_P_NOT_CRASH,
	transition = R2_StopOldSpec_P_EBRAKE_ONLY_IF_IM_NOT_ALLOWED,
	transition = R2_StartNewSpec_P_EBRAKE_DURING_ELASTBRAKE,
	transition = R2_StartNewSpec_P_EBRAKE_IF_SOMETHING_BAD,
	transition = R2_StartNewSpec_P_CHECK_STATUS_AFTER_APPROACHING_CROSSING,
	transition = R2_StartNewSpec_P_BRAKE_DURING_LASTBRAKE,
	transition = R2_StartNewSpec_P_BRAKE_IF_SOMETHING_BAD,
	transition = R2_StartNewSpec_P_NEW_NOT_CRASH,
	transition = R2_StartNewSpec_P_CHECK_STATUS_BEFORE_LAST_EMERGENCY_BRAKE,
	nonblocking,
	selective_fine_grained
}
||UPDATE_CONTROLLER_SFG_R2 = UpdCont_SFG_R2.

// --------------------------- Apply On-The-Fly -----------------------------

updatingController UpdCont_OTF_FG = {
    oldController = OldEnvAndCont,
	oldEnvironment = {MILESTONES_OLD, REQUEST_ATOMIC_OLD, TURNS_OLD, ANOTHER_REQUEST_OLD},
	newEnvironment = {MILESTONES_NEW, REQUEST_ATOMIC_NEW, TURNS_NEW, ANOTHER_REQUEST},
	mapRelation = {R_MILESTONES_FG, R_REQUEST_ATOMIC_FG, R_TURNS_FG, R_ANOTHER_REQUEST_FG},
    oldGoal = OldSpec,
    newGoal = NewSpec,
	nonblocking,
	on_the_fly,
	fine_grained
}
||UPDATE_CONTROLLER_OTF_FG = UpdCont_OTF_FG.

updatingController UpdCont_OTF_FG_R1 = {
    oldController = OldEnvAndCont,
	oldEnvironment = {MILESTONES_OLD, REQUEST_ATOMIC_OLD, TURNS_OLD, ANOTHER_REQUEST_OLD},
	newEnvironment = {MILESTONES_NEW, REQUEST_ATOMIC_NEW, TURNS_NEW, ANOTHER_REQUEST},
	mapRelation = {R_MILESTONES_FG, R_REQUEST_ATOMIC_FG, R_TURNS_FG, R_ANOTHER_REQUEST_FG},
    oldGoal = OldSpec,
