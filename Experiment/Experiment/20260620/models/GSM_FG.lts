// -----------------------------COMMENTS-------------------------------

// - To execute the solution for update controllers select in the dropdown menu 
// the "UPDATE_CONTROLLER" label, and then press the compose button (||).
// - In the section of UPDATING CONTROLLER SPEC, in this file, you can spec
// different transition requeriments presented in the paper.
// - You can animate the controller obtained pressing the blue A in the top bar
// - After composing, you can validate that the controller obtained satisfy 
// each updating controller goal formula by modelchecking.

// ---------------------------ENVIRONMENTS-----------------------------

set OldControllableActions = {shiftX, shiftY, shiftZ, encode, send, receive, decode[2..3], output}
set NewControllableActions = {shiftX, shiftY, shiftZ, shiftT, encode, send, receive, decode[2..3], output}
set AlphabetOld = {OldControllableActions}
set AlphabetNew = {NewControllableActions}

OLD_ENV = SENDER,
SENDER = (shiftX -> X),
X = (shiftY -> Y),
Y = (shiftZ -> Z),
Z = (encode -> ENCODED),
ENCODED = (send -> SENT),
SENT = (receive -> RECEIVED),
RECEIVED = (decode[2..3] -> DECODED),
DECODED = (output -> SENDER).

NEW_ENV = SENDER,
SENDER = (shiftX -> X),
X = (shiftY -> Y),
Y = (shiftZ -> Z),
Z = (shiftT -> T),
T = (encode -> ENCODED),
ENCODED = (send -> SENT),
SENT = (receive -> RECEIVED),
RECEIVED = (decode[2..3] -> DECODED),
DECODED = (output -> SENDER).

||OldEnvironment = (OLD_ENV).
||NewEnvironment = (NEW_ENV).

relation R_ENV = {SENDER@OLD_ENV = reconfigure -> SENDER@NEW_ENV,
					X@OLD_ENV = reconfigure -> X@NEW_ENV,
					Y@OLD_ENV = reconfigure -> Y@NEW_ENV,
					Z@OLD_ENV = reconfigure -> Z@NEW_ENV,
					ENCODED@OLD_ENV = reconfigure -> ENCODED@NEW_ENV,
					SENT@OLD_ENV = reconfigure -> SENT@NEW_ENV,
					RECEIVED@OLD_ENV = reconfigure -> RECEIVED@NEW_ENV,
					DECODED@OLD_ENV = reconfigure -> DECODED@NEW_ENV}

relation R_ENV_FG = {SENDER@OLD_ENV = reconfigure_ENV -> SENDER@NEW_ENV,
					X@OLD_ENV = reconfigure_ENV -> X@NEW_ENV,
					Y@OLD_ENV = reconfigure_ENV -> Y@NEW_ENV,
					Z@OLD_ENV = reconfigure_ENV -> Z@NEW_ENV,
					ENCODED@OLD_ENV = reconfigure_ENV -> ENCODED@NEW_ENV,
					SENT@OLD_ENV = reconfigure_ENV -> SENT@NEW_ENV,
					RECEIVED@OLD_ENV = reconfigure_ENV -> RECEIVED@NEW_ENV,
					DECODED@OLD_ENV = reconfigure_ENV -> DECODED@NEW_ENV}

map MAPPING_ENV = {OLD_ENV, NEW_ENV, R_ENV}.

||MapEnv = (MAPPING_ENV).

// ---------------------------OLD CONTROLLER SPEC -----------------------------

fluent ReadX = <shiftX,output>
fluent ReadY = <shiftY,output>
fluent ReadZ = <shiftZ,output>
fluent ReadT = <shiftT,output>

assert DECODE = (!decode[3])
ltl_property P_DECODE = []DECODE

controllerSpec OldSpec = {
    safety = {P_DECODE}
    controllable = {OldControllableActions}
}

controller ||OldController = OldEnvironment~{OldSpec}.
||OldEnvironmentController = (OldEnvironment || OldController).

// ---------------------------NEW CONTROLLER SPEC -----------------------------

assert NEW_DECODE = (!decode[2])

ltl_property P_NEW_DECODE = []NEW_DECODE

controllerSpec NewSpec = {
    safety = {P_NEW_DECODE}
    controllable = {NewControllableActions}
}

controller ||NewController = NewEnvironment~{NewSpec}.
||NewEnvironmentController = (NewController || NewEnvironment).

// ---------------------------UPDATING CONTROLLER SPEC-----------------------------

set StopOldSpecActions = {stopOldSpec_P_DECODE}
set StartNewSpecActions = {startNewSpec_P_NEW_DECODE}
set ReconfigureActions = {reconfigure_ENV}

fluent Updating = <hotSwapIn,hotSwapOut>
fluent Pending_StopOldSpec_P_DECODE = <hotSwapIn, stopOldSpec_P_DECODE>
fluent Pending_StartNewSpec_P_NEW_DECODE = <hotSwapIn, startNewSpec_P_NEW_DECODE>
fluent Pending_Reconfigure_ENV = <hotSwapIn, reconfigure_ENV>

// T1: 更新中であるならば，更新先制御器の制御可能事象を実行しない
//ltl_property R1 = [](Updating -> !{shiftX, shiftY, shiftZ, shiftT, encode, send, receive, decode[2..3], output})
ltl_property R1 = [](stopOldSpec_P_DECODE -> X(!{shiftX, shiftY, shiftZ, shiftT, encode, send, receive, decode[2..3], output} W startNewSpec_P_NEW_DECODE))

// T2: 各環境モデルを更新（reconfigure）する前に，必ず該当のstopOldSpecとstartNewSpecを実施する
ltl_property R2_StopOldSpec_P_DECODE = [](Pending_StopOldSpec_P_DECODE -> Pending_Reconfigure_ENV)
ltl_property R2_StartNewSpec_P_NEW_DECODE = [](Pending_StartNewSpec_P_NEW_DECODE -> Pending_Reconfigure_ENV)

// --------------------------- NOT On-The-Fly -----------------------------

updatingController UpdCont_FG = {
    oldController = OldEnvironmentController,
	oldEnvironment = {OLD_ENV},
	newEnvironment = {NEW_ENV},
	mapRelation = {R_ENV_FG},
    oldGoal = OldSpec,
    newGoal = NewSpec,
	nonblocking,
	fine_grained
}
||UPDATE_CONTROLLER_FG = UpdCont_FG.

updatingController UpdCont_FG_R1 = {
    oldController = OldEnvironmentController,
	oldEnvironment = {OLD_ENV},
	newEnvironment = {NEW_ENV},
	mapRelation = {R_ENV_FG},
    oldGoal = OldSpec,
    newGoal = NewSpec,
	transition = R1,
	nonblocking,
	fine_grained
}
||UPDATE_CONTROLLER_FG_R1 = UpdCont_FG_R1.

updatingController UpdCont_FG_R2 = {
    oldController = OldEnvironmentController,
	oldEnvironment = {OLD_ENV},
	newEnvironment = {NEW_ENV},
	mapRelation = {R_ENV_FG},
    oldGoal = OldSpec,
    newGoal = NewSpec,
	transition = R2_StopOldSpec_P_DECODE,
	transition = R2_StartNewSpec_P_NEW_DECODE,
	nonblocking,
	fine_grained
}
||UPDATE_CONTROLLER_FG_R2 = UpdCont_FG_R2.

updatingController UpdCont_SFG = {
    oldController = OldEnvironmentController,
	oldEnvironment = {OLD_ENV},
	newEnvironment = {NEW_ENV},
	mapRelation = {R_ENV_FG},
    oldGoal = OldSpec,
    newGoal = NewSpec,
	nonblocking,
	selective_fine_grained
}
||UPDATE_CONTROLLER_SFG = UpdCont_SFG.

updatingController UpdCont_SFG_R1 = {
    oldController = OldEnvironmentController,
	oldEnvironment = {OLD_ENV},
	newEnvironment = {NEW_ENV},
	mapRelation = {R_ENV_FG},
    oldGoal = OldSpec,
    newGoal = NewSpec,
	transition = R1,
	nonblocking,
	selective_fine_grained
}
||UPDATE_CONTROLLER_SFG_R1 = UpdCont_SFG_R1.

updatingController UpdCont_SFG_R2 = {
    oldController = OldEnvironmentController,
	oldEnvironment = {OLD_ENV},
	newEnvironment = {NEW_ENV},
	mapRelation = {R_ENV_FG},
    oldGoal = OldSpec,
    newGoal = NewSpec,
	transition = R2_StopOldSpec_P_DECODE,
	transition = R2_StartNewSpec_P_NEW_DECODE,
	nonblocking,
	selective_fine_grained
}
||UPDATE_CONTROLLER_SFG_R2 = UpdCont_SFG_R2.

// --------------------------- Apply On-The-Fly -----------------------------

updatingController UpdCont_OTF_FG = {
    oldController = OldEnvironmentController,
	oldEnvironment = {OLD_ENV},
	newEnvironment = {NEW_ENV},
	mapRelation = {R_ENV_FG},
    oldGoal = OldSpec,
    newGoal = NewSpec,
	nonblocking,
	on_the_fly,
	fine_grained
}
||UPDATE_CONTROLLER_OTF_FG = UpdCont_OTF_FG.

updatingController UpdCont_OTF_FG_R1 = {
    oldController = OldEnvironmentController,
	oldEnvironment = {OLD_ENV},
	newEnvironment = {NEW_ENV},
	mapRelation = {R_ENV_FG},
    oldGoal = OldSpec,
    newGoal = NewSpec,
	transition = R1,
	nonblocking,
	on_the_fly,
	fine_grained
}
||UPDATE_CONTROLLER_OTF_FG_R1 = UpdCont_OTF_FG_R1.

updatingController UpdCont_OTF_FG_R2 = {
    oldController = OldEnvironmentController,
	oldEnvironment = {OLD_ENV},
	newEnvironment = {NEW_ENV},
	mapRelation = {R_ENV_FG},
    oldGoal = OldSpec,
    newGoal = NewSpec,
	transition = R2_StopOldSpec_P_DECODE,
	transition = R2_StartNewSpec_P_NEW_DECODE,
	nonblocking,
	on_the_fly,
	fine_grained
}
||UPDATE_CONTROLLER_OTF_FG_R2 = UpdCont_OTF_FG_R2.

updatingController UpdCont_OTF_SFG = {
    oldController = OldEnvironmentController,
	oldEnvironment = {OLD_ENV},
	newEnvironment = {NEW_ENV},
	mapRelation = {R_ENV_FG},
    oldGoal = OldSpec,
    newGoal = NewSpec,
	nonblocking,
	on_the_fly,
	selective_fine_grained
}
||UPDATE_CONTROLLER_OTF_SFG = UpdCont_OTF_SFG.

updatingController UpdCont_OTF_SFG_R1 = {
    oldController = OldEnvironmentController,
	oldEnvironment = {OLD_ENV},
	newEnvironment = {NEW_ENV},
	mapRelation = {R_ENV_FG},
    oldGoal = OldSpec,
    newGoal = NewSpec,
	transition = R1,
	nonblocking,
	on_the_fly,
	selective_fine_grained
}
||UPDATE_CONTROLLER_OTF_SFG_R1 = UpdCont_OTF_SFG_R1.

updatingController UpdCont_OTF_SFG_R2 = {
    oldController = OldEnvironmentController,
	oldEnvironment = {OLD_ENV},
	newEnvironment = {NEW_ENV},
	mapRelation = {R_ENV_FG},
    oldGoal = OldSpec,
    newGoal = NewSpec,
	transition = R2_StopOldSpec_P_DECODE,
	transition = R2_StartNewSpec_P_NEW_DECODE,
	nonblocking,
	on_the_fly,
	selective_fine_grained
}
||UPDATE_CONTROLLER_OTF_SFG_R2 = UpdCont_OTF_SFG_R2.

