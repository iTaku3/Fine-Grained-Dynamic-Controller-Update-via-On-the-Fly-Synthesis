// —————————–COMMENTS—————————––

// - To execute the solution for update controllers select in the dropdown menu
// the “UPDATE_CONTROLLER” label, and then press the compose button (||).
// - In the section of UPDATING CONTROLLER SPEC, in this file, you can spec
// different transition requeriments presented in the paper.
// - You can animate the controller obtained pressing the blue A in the top bar
// - After composing, you can validate that the controller obtained satisfy
// each updating controller goal formula by modelchecking.

// —————————ENVIRONMENTS—————————–

set ControllableActions = {initInventory, initCredit, eval, initShipping, initBilling, archive, rollback}
set FirstStep = {initInventory,endInventory,initCredit,endCredit}
set SecondStep = {initShipping, endShipping, initBilling, endBilling}
set All = {ControllableActions, orderEntry, approve, reject, endInventory, endCredit, endShipping, endBilling}

//OldEnvironment
ENTRY_OLD = (orderEntry -> PROCESSING1),
PROCESSING1 = (FirstStep -> PROCESSING1 | eval -> EVAL_RESPONSE | rollback -> ENTRY_OLD),
EVAL_RESPONSE = (approve -> PROCESSING2 | reject -> ENTRY_OLD),
PROCESSING2 = (SecondStep -> PROCESSING2 | {archive,rollback} -> ENTRY_OLD).

INVENTORY_OLD = (initInventory -> AT_INVENTORY),
AT_INVENTORY = (endInventory -> INVENTORY_OLD).

CREDIT_OLD = (initCredit-> AT_CREDIT),
AT_CREDIT = (endCredit-> CREDIT_OLD).

SHIPPING_OLD = (initShipping -> AT_SHIPPING),
AT_SHIPPING = (endShipping -> SHIPPING_OLD).

BILLING_OLD = (initBilling -> AT_BILLING),
AT_BILLING = (endBilling -> BILLING_OLD).

//NewEnvironment
ENTRY_NEW = (orderEntry -> PROCESSING1),
PROCESSING1 = (FirstStep -> PROCESSING1 | eval -> EVAL_RESPONSE | rollback -> ENTRY_NEW),
EVAL_RESPONSE = (approve -> PROCESSING2 | reject -> ENTRY_NEW),
PROCESSING2 = (SecondStep -> PROCESSING2 | {archive,rollback} -> ENTRY_NEW).

INVENTORY_NEW = (initInventory -> AT_INVENTORY),
AT_INVENTORY = (endInventory -> INVENTORY_NEW).

CREDIT_NEW = (initCredit-> AT_CREDIT),
AT_CREDIT = (endCredit-> CREDIT_NEW).

SHIPPING_NEW = (initShipping -> AT_SHIPPING),
AT_SHIPPING = (endShipping -> SHIPPING_NEW).

BILLING_NEW = (initBilling -> AT_BILLING),
AT_BILLING = (endBilling -> BILLING_NEW).

relation R_ENTRY = {ENTRY_OLD@ENTRY_OLD = reconfigure -> ENTRY_NEW@ENTRY_NEW,
PROCESSING1@ENTRY_OLD = reconfigure -> PROCESSING1@ENTRY_NEW,
EVAL_RESPONSE@ENTRY_OLD = reconfigure -> EVAL_RESPONSE@ENTRY_NEW,
PROCESSING2@ENTRY_OLD = reconfigure -> PROCESSING2@ENTRY_NEW}

relation R_ENTRY_FG = {ENTRY_OLD@ENTRY_OLD = reconfigure_ENTRY -> ENTRY_NEW@ENTRY_NEW,
PROCESSING1@ENTRY_OLD = reconfigure_ENTRY -> PROCESSING1@ENTRY_NEW,
EVAL_RESPONSE@ENTRY_OLD = reconfigure_ENTRY -> EVAL_RESPONSE@ENTRY_NEW,
PROCESSING2@ENTRY_OLD = reconfigure_ENTRY -> PROCESSING2@ENTRY_NEW}

relation R_INVENTORY = {INVENTORY_OLD@INVENTORY_OLD = reconfigure -> INVENTORY_NEW@INVENTORY_NEW,
AT_INVENTORY@INVENTORY_OLD = reconfigure -> AT_INVENTORY@INVENTORY_NEW}

relation R_INVENTORY_FG = {INVENTORY_OLD@INVENTORY_OLD = reconfigure_INVENTORY -> INVENTORY_NEW@INVENTORY_NEW,
AT_INVENTORY@INVENTORY_OLD = reconfigure_INVENTORY -> AT_INVENTORY@INVENTORY_NEW}

relation R_CREDIT = {CREDIT_OLD@CREDIT_OLD = reconfigure -> CREDIT_NEW@CREDIT_NEW,
AT_CREDIT@CREDIT_OLD = reconfigure -> AT_CREDIT@CREDIT_NEW}

relation R_CREDIT_FG = {CREDIT_OLD@CREDIT_OLD = reconfigure_CREDIT -> CREDIT_NEW@CREDIT_NEW,
AT_CREDIT@CREDIT_OLD = reconfigure_CREDIT -> AT_CREDIT@CREDIT_NEW}

relation R_SHIPPING = {SHIPPING_OLD@SHIPPING_OLD = reconfigure -> SHIPPING_NEW@SHIPPING_NEW,
AT_SHIPPING@SHIPPING_OLD = reconfigure -> AT_SHIPPING@SHIPPING_NEW}

relation R_SHIPPING_FG = {SHIPPING_OLD@SHIPPING_OLD = reconfigure_SHIPPING -> SHIPPING_NEW@SHIPPING_NEW,
AT_SHIPPING@SHIPPING_OLD = reconfigure_SHIPPING -> AT_SHIPPING@SHIPPING_NEW}

relation R_BILLING = {BILLING_OLD@BILLING_OLD = reconfigure -> BILLING_NEW@BILLING_NEW,
AT_BILLING@BILLING_OLD = reconfigure -> AT_BILLING@BILLING_NEW}

relation R_BILLING_FG = {BILLING_OLD@BILLING_OLD = reconfigure_BILLING -> BILLING_NEW@BILLING_NEW,
AT_BILLING@BILLING_OLD = reconfigure_BILLING -> AT_BILLING@BILLING_NEW}

map MAP_ENTRY = {ENTRY_OLD, ENTRY_NEW, R_ENTRY}.
map MAP_INVENTORY = {INVENTORY_OLD, INVENTORY_NEW, R_INVENTORY}.
map MAP_CREDIT = {CREDIT_OLD, CREDIT_NEW, R_CREDIT}.
map MAP_SHIPPING = {SHIPPING_OLD, SHIPPING_NEW, R_SHIPPING}.
map MAP_BILLING = {BILLING_OLD, BILLING_NEW, R_BILLING}.

||OldEnv = (ENTRY_OLD || INVENTORY_OLD || CREDIT_OLD || SHIPPING_OLD || BILLING_OLD).
||NewEnv = (ENTRY_NEW || INVENTORY_NEW || CREDIT_NEW || SHIPPING_NEW || BILLING_NEW).
||MapEnv = (MAP_ENTRY || MAP_INVENTORY || MAP_CREDIT || MAP_SHIPPING || MAP_BILLING).

//Fluents declaration
fluent InventoryFinished = <endInventory,{orderEntry}>
fluent CreditFinished = <endCredit,{orderEntry}>
fluent ShippingFinished = <endShipping,{orderEntry}>
fluent BillingFinished = <endBilling,{orderEntry}>

fluent InventoryInitiated = <initInventory,{orderEntry}>
fluent CreditInitiated = <initCredit,{orderEntry}>
fluent ShippingInitiated = <initShipping,{orderEntry}>
fluent BillingInitiated = <initBilling,{orderEntry}>

fluent OrderArrived = <orderEntry, {archive,rollback,reject}>
fluent OrderApproved = <approve, {orderEntry}>

// —————————CONCURRENT CONTROLLER SPEC (old system)—————————–
//Action Fluents

assert ARCHIVE_POLICY = (archive -> (ShippingFinished && BillingFinished))
assert EVAL_POLICY = (eval-> (InventoryFinished && CreditFinished))
assert INITS_POLICY = ((initInventory -> OrderArrived) && (initCredit -> OrderArrived) &&
(initShipping -> OrderApproved) && (initBilling -> OrderApproved))
assert DONT_INIT_TWICE = ((InventoryFinished -> !initInventory) && (CreditFinished -> !initCredit) &&
(ShippingFinished -> !initShipping) && (BillingFinished -> !initBilling) )

assert AVOID_ROLLBACK = (!rollback)

ltl_property P_ARCHIVE_POLICY = []ARCHIVE_POLICY
ltl_property P_EVAL_POLICY = []EVAL_POLICY
ltl_property P_INITS_POLICY = []INITS_POLICY
ltl_property P_DONT_INIT_TWICE = []DONT_INIT_TWICE
ltl_property P_AVOID_ROLLBACK = []AVOID_ROLLBACK

controllerSpec ConcurrentSpec = {
safety = {P_AVOID_ROLLBACK, P_EVAL_POLICY, P_ARCHIVE_POLICY, P_INITS_POLICY, P_DONT_INIT_TWICE}
controllable = {ControllableActions}
}

//controller ||ConcurrentController = Environment~{ConcurrentSpec}.
controller ||OldController = OldEnv~{ConcurrentSpec}.
//||Concurrent = (ConcurrentController || Environment).
||OldEnvironmentAndController = (OldController || OldEnv).

// —————————SEQUENTIAL CONTROLLER SPEC (new system)—————————–

assert SEQUENTIAL = (((ShippingInitiated || ShippingFinished) -> BillingFinished))

ltl_property P_SEQUENTIAL = []SEQUENTIAL

controllerSpec SequentialSpec = {
safety = {P_SEQUENTIAL,P_AVOID_ROLLBACK,P_EVAL_POLICY, P_ARCHIVE_POLICY, P_INITS_POLICY, P_DONT_INIT_TWICE}
controllable = {ControllableActions}
}

//controller ||SequentialController = Environment~{SequentialSpec}.
controller ||NewController = NewEnv~{SequentialSpec}.
//||Sequential = (SequentialController || Environment).
||NewEnvironmentAndController = (NewController || NewEnv).

// —————————UPDATING CONTROLLER SPEC—————————–

/*
//Fluents for updates
fluent EvalPending = <eval,{approve,reject}>
fluent StopOldSpec = <stopOldSpec, hotSwapIn>
fluent StartNewSpec = <startNewSpec, hotSwapIn>
fluent Reconfigure = <reconfigure, hotSwapIn>

assert AnyAction = (initInventory || initCredit || endInventory || endCredit || eval || endShipping || endBilling
|| initShipping || initBilling || archive || rollback || orderEntry || approve || reject)

ltl_property R1 = []((StopOldSpec && !StartNewSpec) -> !{initInventory, initCredit, endInventory, endCredit, eval, endShipping, endBilling,
initShipping, initBilling, archive, rollback, orderEntry, approve, reject})
*/
// Selective fine-grained transition requirement.
//ltl_property SFG_REFERENCE = []({stopOldSpec_P_AVOID_ROLLBACK, reconfigure_ENTRY, startNewSpec_P_SEQUENTIAL} -> {stopOldSpec_P_AVOID_ROLLBACK, reconfigure_ENTRY, startNewSpec_P_SEQUENTIAL})

// Update Requirement for Fine-Grained
// T1: 更新中であるならば，更新先制御器の制御可能事象を実行しない
// T2: 各環境モデルを更新（reconfigure）する前に，必ず該当のstopOldSpecとstartNewSpecを実施する（要求ベースがいいかも）
set StopOldSpecActions = {stopOldSpec_P_AVOID_ROLLBACK, stopOldSpec_P_EVAL_POLICY, stopOldSpec_P_ARCHIVE_POLICY, stopOldSpec_P_INITS_POLICY, stopOldSpec_P_DONT_INIT_TWICE}
set StartNewSpecActions = {startNewSpec_P_SEQUENTIAL, startNewSpec_P_AVOID_ROLLBACK, startNewSpec_P_EVAL_POLICY, startNewSpec_P_ARCHIVE_POLICY, startNewSpec_P_INITS_POLICY, startNewSpec_P_DONT_INIT_TWICE}
set ReconfigureActions = {reconfigure_ENTRY, reconfigure_INVENTORY, reconfigure_CREDIT, reconfigure_SHIPPING,reconfigure_BILLING}

fluent Updating = <hotSwapIn,hotSwapOut>

fluent Pending_StopOldSpec_P_AVOID_ROLLBACK  = <hotSwapIn, stopOldSpec_P_AVOID_ROLLBACK>
fluent Pending_StopOldSpec_P_EVAL_POLICY  = <hotSwapIn, stopOldSpec_P_EVAL_POLICY>
fluent Pending_StopOldSpec_P_ARCHIVE_POLICY  = <hotSwapIn, stopOldSpec_P_ARCHIVE_POLICY>
fluent Pending_StopOldSpec_P_INITS_POLICY  = <hotSwapIn, stopOldSpec_P_INITS_POLICY>
fluent Pending_StopOldSpec_P_DONT_INIT_TWICE  = <hotSwapIn, stopOldSpec_P_DONT_INIT_TWICE>

fluent Pending_StartNewSpec_P_SEQUENTIAL = <hotSwapIn, startNewSpec_P_SEQUENTIAL>
fluent Pending_StartNewSpec_P_AVOID_ROLLBACK = <hotSwapIn, startNewSpec_P_AVOID_ROLLBACK>
fluent Pending_StartNewSpec_P_EVAL_POLICY = <hotSwapIn, startNewSpec_P_EVAL_POLICY>
fluent Pending_StartNewSpec_P_ARCHIVE_POLICY = <hotSwapIn, startNewSpec_P_ARCHIVE_POLICY>
fluent Pending_StartNewSpec_P_INITS_POLICY = <hotSwapIn, startNewSpec_P_INITS_POLICY>
fluent Pending_StartNewSpec_P_DONT_INIT_TWICE = <hotSwapIn, startNewSpec_P_DONT_INIT_TWICE>

fluent Pending_Reconfigure_ENTRY     = <hotSwapIn, reconfigure_ENTRY>
fluent Pending_Reconfigure_INVENTORY = <hotSwapIn, reconfigure_INVENTORY>
fluent Pending_Reconfigure_CREDIT    = <hotSwapIn, reconfigure_CREDIT>
fluent Pending_Reconfigure_SHIPPING  = <hotSwapIn, reconfigure_SHIPPING>
fluent Pending_Reconfigure_BILLING   = <hotSwapIn, reconfigure_BILLING>

//ltl_property R1 = [](Updating -> !{initInventory, initCredit, eval, initShipping, initBilling, archive, rollback})
ltl_property R1 = []({stopOldSpec_P_AVOID_ROLLBACK, stopOldSpec_P_EVAL_POLICY, stopOldSpec_P_ARCHIVE_POLICY, stopOldSpec_P_INITS_POLICY, stopOldSpec_P_DONT_INIT_TWICE} -> X(!{initInventory, initCredit, eval, initShipping, initBilling, archive, rollback} W {startNewSpec_P_SEQUENTIAL, startNewSpec_P_AVOID_ROLLBACK, startNewSpec_P_EVAL_POLICY, startNewSpec_P_ARCHIVE_POLICY, startNewSpec_P_INITS_POLICY, startNewSpec_P_DONT_INIT_TWICE}))

ltl_property R2_StopOldSpec_P_AVOID_ROLLBACK = [](Pending_StopOldSpec_P_AVOID_ROLLBACK -> Pending_Reconfigure_ENTRY)
ltl_property R2_StopOldSpec_P_EVAL_POLICY = [](Pending_StopOldSpec_P_EVAL_POLICY -> (Pending_Reconfigure_ENTRY && Pending_Reconfigure_INVENTORY && Pending_Reconfigure_CREDIT))
ltl_property R2_StopOldSpec_P_ARCHIVE_POLICY = [](Pending_StopOldSpec_P_ARCHIVE_POLICY -> (Pending_Reconfigure_ENTRY && Pending_Reconfigure_SHIPPING && Pending_Reconfigure_BILLING))
ltl_property R2_StopOldSpec_P_INITS_POLICY = [](Pending_StopOldSpec_P_INITS_POLICY -> (Pending_Reconfigure_ENTRY && Pending_Reconfigure_INVENTORY && Pending_Reconfigure_CREDIT && Pending_Reconfigure_SHIPPING && Pending_Reconfigure_BILLING))
ltl_property R2_StopOldSpec_P_DONT_INIT_TWICE = [](Pending_StopOldSpec_P_DONT_INIT_TWICE -> (Pending_Reconfigure_ENTRY && Pending_Reconfigure_INVENTORY && Pending_Reconfigure_CREDIT && Pending_Reconfigure_SHIPPING && Pending_Reconfigure_BILLING))
ltl_property R2_StartNewSpec_P_SEQUENTIAL = [](Pending_StartNewSpec_P_SEQUENTIAL -> (Pending_Reconfigure_ENTRY && Pending_Reconfigure_SHIPPING && Pending_Reconfigure_BILLING))
ltl_property R2_StartNewSpec_P_AVOID_ROLLBACK = [](Pending_StartNewSpec_P_AVOID_ROLLBACK -> Pending_Reconfigure_ENTRY)
ltl_property R2_StartNewSpec_P_EVAL_POLICY = [](Pending_StartNewSpec_P_EVAL_POLICY -> (Pending_Reconfigure_ENTRY && Pending_Reconfigure_INVENTORY && Pending_Reconfigure_CREDIT))
ltl_property R2_StartNewSpec_P_ARCHIVE_POLICY = [](Pending_StartNewSpec_P_ARCHIVE_POLICY -> (Pending_Reconfigure_ENTRY && Pending_Reconfigure_SHIPPING && Pending_Reconfigure_BILLING))
ltl_property R2_StartNewSpec_P_INITS_POLICY = [](Pending_StartNewSpec_P_INITS_POLICY -> (Pending_Reconfigure_ENTRY && Pending_Reconfigure_INVENTORY && Pending_Reconfigure_CREDIT && Pending_Reconfigure_SHIPPING && Pending_Reconfigure_BILLING))
ltl_property R2_StartNewSpec_P_DONT_INIT_TWICE = [](Pending_StartNewSpec_P_DONT_INIT_TWICE -> (Pending_Reconfigure_ENTRY && Pending_Reconfigure_INVENTORY && Pending_Reconfigure_CREDIT && Pending_Reconfigure_SHIPPING && Pending_Reconfigure_BILLING))

// ————————— NOT On-The-Fly —————————–

updatingController UpdCont_FG = {
oldController = OldEnvironmentAndController,
oldEnvironment = {ENTRY_OLD, INVENTORY_OLD, CREDIT_OLD, SHIPPING_OLD, BILLING_OLD},
newEnvironment = {ENTRY_NEW, INVENTORY_NEW, CREDIT_NEW, SHIPPING_NEW, BILLING_NEW},
mapRelation = {R_ENTRY_FG, R_INVENTORY_FG, R_CREDIT_FG, R_SHIPPING_FG, R_BILLING_FG},
oldGoal = ConcurrentSpec,
newGoal = SequentialSpec,
nonblocking,
fine_grained
}
||UPDATE_CONTROLLER_FG = UpdCont_FG.

updatingController UpdCont_FG_R1 = {
oldController = OldEnvironmentAndController,
oldEnvironment = {ENTRY_OLD, INVENTORY_OLD, CREDIT_OLD, SHIPPING_OLD, BILLING_OLD},
newEnvironment = {ENTRY_NEW, INVENTORY_NEW, CREDIT_NEW, SHIPPING_NEW, BILLING_NEW},
mapRelation = {R_ENTRY_FG, R_INVENTORY_FG, R_CREDIT_FG, R_SHIPPING_FG, R_BILLING_FG},
oldGoal = ConcurrentSpec,
newGoal = SequentialSpec,
transition = R1,
nonblocking,
fine_grained
}
||UPDATE_CONTROLLER_FG_R1 = UpdCont_FG_R1.

updatingController UpdCont_FG_R2 = {
oldController = OldEnvironmentAndController,
oldEnvironment = {ENTRY_OLD, INVENTORY_OLD, CREDIT_OLD, SHIPPING_OLD, BILLING_OLD},
newEnvironment = {ENTRY_NEW, INVENTORY_NEW, CREDIT_NEW, SHIPPING_NEW, BILLING_NEW},
mapRelation = {R_ENTRY_FG, R_INVENTORY_FG, R_CREDIT_FG, R_SHIPPING_FG, R_BILLING_FG},
oldGoal = ConcurrentSpec,
newGoal = SequentialSpec,
transition = R2_StopOldSpec_P_AVOID_ROLLBACK,
transition = R2_StopOldSpec_P_EVAL_POLICY,
transition = R2_StopOldSpec_P_ARCHIVE_POLICY,
transition = R2_StopOldSpec_P_INITS_POLICY,
transition = R2_StopOldSpec_P_DONT_INIT_TWICE,
transition = R2_StartNewSpec_P_SEQUENTIAL,
transition = R2_StartNewSpec_P_AVOID_ROLLBACK,
transition = R2_StartNewSpec_P_EVAL_POLICY,
transition = R2_StartNewSpec_P_ARCHIVE_POLICY,
transition = R2_StartNewSpec_P_INITS_POLICY,
transition = R2_StartNewSpec_P_DONT_INIT_TWICE,
nonblocking,
fine_grained
}
||UPDATE_CONTROLLER_FG_R2 = UpdCont_FG_R2.

updatingController UpdCont_SFG = {
oldController = OldEnvironmentAndController,
oldEnvironment = {ENTRY_OLD, INVENTORY_OLD, CREDIT_OLD, SHIPPING_OLD, BILLING_OLD},
newEnvironment = {ENTRY_NEW, INVENTORY_NEW, CREDIT_NEW, SHIPPING_NEW, BILLING_NEW},
mapRelation = {R_ENTRY_FG, R_INVENTORY_FG, R_CREDIT_FG, R_SHIPPING_FG, R_BILLING_FG},
oldGoal = ConcurrentSpec,
newGoal = SequentialSpec,
nonblocking,
selective_fine_grained
}
||UPDATE_CONTROLLER_SFG = UpdCont_SFG.

updatingController UpdCont_SFG_R1 = {
oldController = OldEnvironmentAndController,
oldEnvironment = {ENTRY_OLD, INVENTORY_OLD, CREDIT_OLD, SHIPPING_OLD, BILLING_OLD},
newEnvironment = {ENTRY_NEW, INVENTORY_NEW, CREDIT_NEW, SHIPPING_NEW, BILLING_NEW},
mapRelation = {R_ENTRY_FG, R_INVENTORY_FG, R_CREDIT_FG, R_SHIPPING_FG, R_BILLING_FG},
oldGoal = ConcurrentSpec,
newGoal = SequentialSpec,
transition = R1,
nonblocking,
selective_fine_grained
}
||UPDATE_CONTROLLER_SFG_R1 = UpdCont_SFG_R1.

updatingController UpdCont_SFG_R2 = {
oldController = OldEnvironmentAndController,
oldEnvironment = {ENTRY_OLD, INVENTORY_OLD, CREDIT_OLD, SHIPPING_OLD, BILLING_OLD},
newEnvironment = {ENTRY_NEW, INVENTORY_NEW, CREDIT_NEW, SHIPPING_NEW, BILLING_NEW},
mapRelation = {R_ENTRY_FG, R_INVENTORY_FG, R_CREDIT_FG, R_SHIPPING_FG, R_BILLING_FG},
oldGoal = ConcurrentSpec,
newGoal = SequentialSpec,
transition = R2_StopOldSpec_P_AVOID_ROLLBACK,
transition = R2_StopOldSpec_P_EVAL_POLICY,
transition = R2_StopOldSpec_P_ARCHIVE_POLICY,
transition = R2_StopOldSpec_P_INITS_POLICY,
transition = R2_StopOldSpec_P_DONT_INIT_TWICE,
transition = R2_StartNewSpec_P_SEQUENTIAL,
transition = R2_StartNewSpec_P_AVOID_ROLLBACK,
transition = R2_StartNewSpec_P_EVAL_POLICY,
transition = R2_StartNewSpec_P_ARCHIVE_POLICY,
transition = R2_StartNewSpec_P_INITS_POLICY,
transition = R2_StartNewSpec_P_DONT_INIT_TWICE,
nonblocking,
selective_fine_grained
}
||UPDATE_CONTROLLER_SFG_R2 = UpdCont_SFG_R2.

// ————————— Apply On-The-Fly —————————–

updatingController UpdCont_OTF_FG = {
oldController = OldEnvironmentAndController,
oldEnvironment = {ENTRY_OLD, INVENTORY_OLD, CREDIT_OLD, SHIPPING_OLD, BILLING_OLD},
newEnvironment = {ENTRY_NEW, INVENTORY_NEW, CREDIT_NEW, SHIPPING_NEW, BILLING_NEW},
mapRelation = {R_ENTRY_FG, R_INVENTORY_FG, R_CREDIT_FG, R_SHIPPING_FG, R_BILLING_FG},
